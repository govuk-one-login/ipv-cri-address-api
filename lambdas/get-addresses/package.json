{
    "name": "get-addresses",
    "scripts": {
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "unit": "vitest run",
        "test": "npm run unit --",
        "test:coverage": "npm run unit -- --coverage",
        "sam:validate": "cd ../../infrastructure/lambda && sam validate && sam validate --lint",
        "sam:build": "npm run sam:validate && sam build --template ../../infrastructure/lambda/template.yaml --cached --parallel",
        "deploy": "../../deploy.sh",
        "compile": "tsc"
    },
    "dependencies": {
        "@aws-lambda-powertools/logger": "^2.10.0",
        "@aws-lambda-powertools/parameters": "2.10.0",
        "@aws-sdk/client-dynamodb": "3.1005.0",
        "@aws-sdk/client-ssm": "3.1005.0",
        "@aws-sdk/lib-dynamodb": "3.1005.0",
        "@opentelemetry/api": "^1.9.1",
        "@opentelemetry/instrumentation-aws-lambda": "^0.69.0",
        "@opentelemetry/instrumentation-aws-sdk": "^0.72.0",
        "@opentelemetry/instrumentation-dns": "^0.60.0",
        "@opentelemetry/instrumentation-fs": "^0.36.0",
        "@opentelemetry/instrumentation-http": "^0.217.0",
        "@opentelemetry/instrumentation-net": "^0.61.0",
        "@opentelemetry/instrumentation-undici": "^0.27.0",
        "@opentelemetry/resource-detector-aws": "^2.17.0",
        "@opentelemetry/resources": "^2.7.1",
        "@opentelemetry/sdk-node": "^0.217.0",
        "esbuild": "0.25.0"
    },
    "devDependencies": {
        "@types/aws-lambda": "8.10.149",
        "@types/node": "22.12.0",
        "@typescript-eslint/eslint-plugin": "^7.6.0",
        "@typescript-eslint/parser": "^7.6.0",
        "@vitest/coverage-v8": "^4.1.5",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.3",
        "prettier": "^3.3.3",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.2",
        "vitest": "^4.1.5"
    }
}
